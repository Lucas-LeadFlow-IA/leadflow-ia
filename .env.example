# ===========================================
# LeadFlow IA - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# Groq API - Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Stripe - Get your keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Optional: Stripe Price IDs (created via dashboard or API)
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly_id
STRIPE_PRICE_AGENCY_MONTHLY=price_agency_monthly_id
STRIPE_PRICE_AGENCY_YEARLY=price_agency_yearly_id

# App URL (update for production)
NEXT_PUBLIC_APP_URL=https://leadflow-ia.com

# Supabase (optional - for real auth)
# SUPABASE_URL=your_supabase_url
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_KEY=your_supabase_service_key