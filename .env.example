# ===========================================
# LeadFlow IA - Variables d'environnement
# ===========================================
# Copie ce fichier vers .env.local et remplis les valeurs

# ===========================================
# GROQ API - IA (Obligatoire)
# ===========================================
# Obtiens ta clé gratuitement sur https://console.groq.com
GROQ_API_KEY=votre_cle_groq_ici

# ===========================================
# STRIPE - Paiements
# ===========================================
# Obtiens tes clés sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_votre_cle_stripe_ici

# Clé publique (côté client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_votre_cle_publique_ici

# Webhook secret (après avoir créé un webhook sur Stripe Dashboard)
STRIPE_WEBHOOK_SECRET=whsec_votre_webhook_secret_ici

# ===========================================
# SUPABASE - Base de données (Optionnel)
# ===========================================
# Si tu n'utilises pas Supabase, le système fonctionne avec localStorage
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon_ici
SUPABASE_SERVICE_ROLE_KEY=votre_cle_service_role_ici

# ===========================================
# APPLICATION
# ===========================================
# URL de l'application (mettre à jour en production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# RESEND - Emails (Optionnel)
# ===========================================
# Pour activer les emails de bienvenue
# RESEND_API_KEY=re_votre_cle_resend_ici